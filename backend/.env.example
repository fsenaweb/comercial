APP_NAME="Sistema Comercial"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
# Em produção na LAN: http://<ip-do-servidor> (ex.: http://192.168.0.10)
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=comercial
DB_USERNAME=comercial
DB_PASSWORD=comercial

# Hosts/IPs que os navegadores usam para acessar o sistema — o Sanctum só trata
# como sessão stateful (cookie) requisições vindas dessas origens. Em produção
# na LAN, OBRIGATÓRIO incluir o IP do servidor (ex.: 192.168.0.10), senão o
# login não persiste nos terminais. Se usar um hostname local via /etc/hosts
# (ex.: loja.local) para testar, adicione aqui também. Ver docs/07-dev-environment.md.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1

# Origens extras liberadas no CORS (só relevante para o `npm run dev` do Nuxt;
# em produção front e back são a mesma origem via nginx).
CORS_ALLOWED_ORIGINS=http://localhost:3000

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# null: cookie fica restrito ao host que de fato serviu a requisição — funciona
# em qualquer host/IP sem precisar listar cada um aqui (dev ou produção).
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
